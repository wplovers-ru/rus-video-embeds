{
    "name": "rus-video-embeds",
    "version": "1.0.0",
    "description": "WordPress plugin for embedding VK Video, Rutube and Dzen videos",
    "private": true,
    "scripts": {
        "build": "wp-scripts build --webpack-src-dir=blocks/video/src --output-path=blocks/video/build",
        "start": "wp-scripts start --webpack-src-dir=blocks/video/src --output-path=blocks/video/build"
    },
    "devDependencies": {
        "@wordpress/scripts": "^30.0.0"
    }
}
