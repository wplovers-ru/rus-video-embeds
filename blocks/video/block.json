{
    "apiVersion": 3,
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "name": "rus-video-embeds/video",
    "version": "1.1.1",
    "title": "RU Video",
    "category": "embed",
    "icon": "video-alt3",
    "description": "Embed videos from VK Video, Rutube, and Dzen",
    "keywords": ["video", "видео", "vk", "rutube", "дзен", "dzen", "embed"],
    "textdomain": "rus-video-embeds",
    "supports": {
        "html": false,
        "align": ["wide", "full"],
        "spacing": {
            "margin": ["top", "bottom"]
        }
    },
    "attributes": {
        "url": {
            "type": "string",
            "default": ""
        },
        "aspectRatio": {
            "type": "string",
            "default": "16:9"
        },
        "autoplay": {
            "type": "boolean",
            "default": false
        }
    },
    "editorScript": "file:./build/index.js",
    "editorStyle": "rve-embed-editor-styles"
}
